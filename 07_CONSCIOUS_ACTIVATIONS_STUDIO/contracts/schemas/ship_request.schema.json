{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "artifact_id": {
            "minLength": 1,
            "type": "string"
          },
          "artifact_kind": {
            "minLength": 1,
            "type": "string"
          },
          "bytes": {
            "minimum": 1,
            "type": "integer"
          },
          "media_type": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "uri": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "artifact_id",
          "artifact_kind",
          "bytes",
          "media_type",
          "sha256",
          "uri"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "autonomy_mode": {
      "enum": [
        "AUTOPILOT",
        "REVIEW_BEFORE_SHIP",
        "CHECKPOINTED",
        "SHADOW"
      ],
      "type": "string"
    },
    "campaign_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "evaluation_refs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "object_id": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "version": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "object_id",
          "version",
          "sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "operator_actor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "type": "string"
        },
        "actor_type": {
          "enum": [
            "deterministic_module",
            "model_program",
            "human"
          ],
          "type": "string"
        },
        "product_id": {
          "minLength": 1,
          "type": "string"
        },
        "workflow_role": {
          "enum": [
            "hunter",
            "analyst",
            "composer",
            "commander",
            "evaluator",
            "operator"
          ],
          "type": "string"
        }
      },
      "required": [
        "actor_id",
        "actor_type",
        "product_id",
        "workflow_role"
      ],
      "type": "object"
    },
    "publication_authority_ref": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "object_id": {
              "minLength": 1,
              "type": "string"
            },
            "sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "version": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "object_id",
            "version",
            "sha256"
          ],
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "publication_policy_ref": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "object_id": {
              "minLength": 1,
              "type": "string"
            },
            "sha256": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "version": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "object_id",
            "version",
            "sha256"
          ],
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "ship_request_id": {
      "minLength": 1,
      "type": "string"
    },
    "target_channel": {
      "minLength": 1,
      "type": "string"
    },
    "unresolved_exception_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "ship_request_id",
    "campaign_ref",
    "autonomy_mode",
    "target_channel",
    "artifact_refs",
    "evaluation_refs",
    "unresolved_exception_ids",
    "operator_actor",
    "publication_authority_ref",
    "publication_policy_ref"
  ],
  "title": "ShipRequest",
  "type": "object"
}
