{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accepted": {
      "type": "boolean"
    },
    "category_id": {
      "minLength": 1,
      "type": "string"
    },
    "dispositions": {
      "type": "object"
    },
    "episode_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "harness_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "record_id": {
      "minLength": 1,
      "type": "string"
    },
    "retrieval_tokens": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "scope": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "record_id",
    "episode_ref",
    "retrieval_tokens",
    "category_id",
    "harness_ref",
    "scope",
    "accepted",
    "dispositions"
  ],
  "title": "ProgrammingMaterialRecord",
  "type": "object"
}
