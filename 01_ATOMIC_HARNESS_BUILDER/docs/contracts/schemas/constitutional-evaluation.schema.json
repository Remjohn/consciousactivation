{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmf://builder/contracts/constitutional-evaluation/v1",
  "title": "Constitutional Evaluation, Readiness, and Control Tower Projection",
  "$ref": "#/$defs/ConstitutionalEvaluationReceipt",
  "$defs": {
    "VersionedRef": {"type": "object", "additionalProperties": false, "required": ["object_id", "version", "sha256"], "properties": {"object_id": {"type": "string"}, "version": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}},
    "DimensionResult": {"type": "object", "additionalProperties": false, "required": ["dimension", "result", "evidence_refs", "non_compensable"], "properties": {"dimension": {"enum": ["activation_specificity", "role_activation", "reaction_integrity", "expression_provenance", "visual_recognition", "narrative_sequence", "wrong_reading_control", "semantic_lineage", "category_native_syntax", "external_boundary"]}, "result": {"enum": ["PASS", "FAIL", "NOT_EVALUATED"]}, "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/VersionedRef"}}, "non_compensable": {"type": "boolean"}}},
    "ConstitutionalEvaluationReceipt": {"type": "object", "additionalProperties": false, "required": ["receipt_id", "subject_ref", "profile_id", "dimensions", "hard_gates", "decision", "corpus_ref", "evaluator_refs"], "properties": {"receipt_id": {"type": "string"}, "subject_ref": {"$ref": "#/$defs/VersionedRef"}, "profile_id": {"type": "string"}, "dimensions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/DimensionResult"}}, "hard_gates": {"type": "object", "required": ["HG-015"], "additionalProperties": {"enum": ["PASS", "FAIL", "NOT_EVALUATED"]}}, "decision": {"enum": ["PASS", "FAIL", "BLOCKED"]}, "corpus_ref": {"$ref": "#/$defs/VersionedRef"}, "evaluator_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/VersionedRef"}}}},
    "ConstitutionalReadinessReceipt": {"type": "object", "additionalProperties": false, "required": ["readiness_id", "evaluation_receipt_refs", "contract_registry_ref", "gate_results", "result"], "properties": {"readiness_id": {"type": "string"}, "evaluation_receipt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/VersionedRef"}}, "contract_registry_ref": {"$ref": "#/$defs/VersionedRef"}, "gate_results": {"type": "object", "required": ["HG-015"], "additionalProperties": {"enum": ["PASS", "FAIL"]}}, "result": {"enum": ["PASS", "FAIL"]}}},
    "ControlTowerConstitutionalProjection": {"type": "object", "additionalProperties": false, "required": ["run_id", "event_stream_version", "category_id", "profile_id", "semantic_lineage_refs", "reaction_receipt_refs", "expression_moment_refs", "wrong_reading_locks", "gate_results", "external_handoffs"], "properties": {"run_id": {"type": "string"}, "event_stream_version": {"type": "integer", "minimum": 0}, "category_id": {"type": "string"}, "profile_id": {"type": "string"}, "semantic_lineage_refs": {"type": "array", "items": {"$ref": "#/$defs/VersionedRef"}}, "reaction_receipt_refs": {"type": "array", "items": {"$ref": "#/$defs/VersionedRef"}}, "expression_moment_refs": {"type": "array", "items": {"$ref": "#/$defs/VersionedRef"}}, "wrong_reading_locks": {"type": "array", "items": {"type": "string"}}, "gate_results": {"type": "object"}, "external_handoffs": {"type": "array", "items": {"$ref": "#/$defs/VersionedRef"}}}}
  }
}
