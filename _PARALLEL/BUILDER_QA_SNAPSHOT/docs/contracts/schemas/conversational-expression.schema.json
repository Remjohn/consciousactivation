{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmf://builder/contracts/conversational-expression/v1",
  "title": "Conversational Activation and Human Expression",
  "type": "object",
  "additionalProperties": false,
  "required": ["category_id", "profile_id", "certification", "runtime_law", "activative_intelligence_pack_ref", "calls", "reaction_receipts", "expression_moments"],
  "properties": {
    "category_id": {"const": "conversational_activation_expression"},
    "profile_id": {"enum": ["public_comment", "reply_dm", "reelcast_expression", "interview_expression"]},
    "certification": {"const": "UNCERTIFIED"},
    "runtime_law": {"const": "Activation First"},
    "activative_intelligence_pack_ref": {"$ref": "#/$defs/VersionedRef"},
    "calls": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ActivativeCall"}},
    "reaction_receipts": {"type": "array", "items": {"$ref": "#/$defs/ReactionReceipt"}},
    "expression_moments": {"type": "array", "items": {"$ref": "#/$defs/ExpressionMoment"}},
    "identity_dna_amendment_proposals": {"type": "array", "items": {"$ref": "#/$defs/IdentityDNAAmendmentProposal"}}
  },
  "$defs": {
    "VersionedRef": {
      "type": "object", "additionalProperties": false,
      "required": ["object_id", "version", "sha256"],
      "properties": {"object_id": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
    },
    "EvidenceSpan": {
      "type": "object", "additionalProperties": false,
      "required": ["source_ref", "start", "end", "kind"],
      "properties": {"source_ref": {"$ref": "#/$defs/VersionedRef"}, "start": {"type": "number", "minimum": 0}, "end": {"type": "number", "exclusiveMinimum": 0}, "kind": {"enum": ["character", "timecode", "turn"]}}
    },
    "ActivativeCall": {
      "type": "object", "additionalProperties": false,
      "required": ["call_id", "surface", "pack_ref", "call_text_or_event", "intended_reaction", "smallest_useful_commitment", "wrong_reading_locks"],
      "properties": {"call_id": {"type": "string"}, "surface": {"type": "string"}, "pack_ref": {"$ref": "#/$defs/VersionedRef"}, "call_text_or_event": {"type": "string", "minLength": 1}, "intended_reaction": {"type": "string", "minLength": 1}, "smallest_useful_commitment": {"type": "string", "minLength": 1}, "wrong_reading_locks": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
    },
    "ReactionReceipt": {
      "type": "object", "additionalProperties": false,
      "required": ["receipt_id", "call_id", "evidence_spans", "reaction_functions", "consent_policy_ref", "withdrawal_status", "recompile_disposition", "captured_by"],
      "properties": {"receipt_id": {"type": "string"}, "call_id": {"type": "string"}, "evidence_spans": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceSpan"}}, "reaction_functions": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "consent_policy_ref": {"$ref": "#/$defs/VersionedRef"}, "withdrawal_status": {"enum": ["ACTIVE", "WITHDRAWN", "RESTRICTED"]}, "recompile_disposition": {"enum": ["CONTINUE", "ELEVATE", "CLOSE", "RECOMPILE", "HUMAN_REVIEW"]}, "captured_by": {"type": "string"}}
    },
    "ExpressionMoment": {
      "type": "object", "additionalProperties": false,
      "required": ["moment_id", "reaction_receipt_ref", "evidence_spans", "expression_functions", "landing_status", "routeability", "withdrawal_status"],
      "properties": {"moment_id": {"type": "string"}, "reaction_receipt_ref": {"$ref": "#/$defs/VersionedRef"}, "evidence_spans": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/EvidenceSpan"}}, "expression_functions": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "landing_status": {"enum": ["OBSERVED", "HYPOTHESIZED", "RATIFIED"]}, "routeability": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "withdrawal_status": {"enum": ["ACTIVE", "WITHDRAWN", "RESTRICTED"]}}
    },
    "IdentityDNAAmendmentProposal": {
      "type": "object", "additionalProperties": false,
      "required": ["proposal_id", "source_receipt_refs", "proposed_changes", "status", "merge_authority"],
      "properties": {"proposal_id": {"type": "string"}, "source_receipt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/VersionedRef"}}, "proposed_changes": {"type": "array", "minItems": 1, "items": {"type": "object"}}, "status": {"enum": ["PENDING_HUMAN_REVIEW", "APPROVED", "REJECTED", "WITHDRAWN"]}, "merge_authority": {"const": "human_identity_authority"}}
    }
  }
}
