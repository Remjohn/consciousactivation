{
  "$id": "urn:conscious-activations:activative-production-spine:0.1.0-dev.1:product-handoff-envelope",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Typed cross-product handoff preserving source lineage and wrong-reading locks.",
  "properties": {
    "authority": {
      "$ref": "authority-ref.schema.json"
    },
    "consumer_product": {
      "minLength": 1,
      "type": "string"
    },
    "created_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "handoff_id": {
      "minLength": 1,
      "type": "string"
    },
    "object_ref": {
      "$ref": "immutable-ref.schema.json"
    },
    "object_schema": {
      "minLength": 1,
      "type": "string"
    },
    "object_schema_version": {
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "producer_product": {
      "minLength": 1,
      "type": "string"
    },
    "source_lineage_refs": {
      "items": {
        "$ref": "immutable-ref.schema.json"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "wrong_reading_lock_refs": {
      "items": {
        "$ref": "immutable-ref.schema.json"
      },
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "handoff_id",
    "producer_product",
    "consumer_product",
    "object_ref",
    "object_schema",
    "object_schema_version",
    "authority",
    "source_lineage_refs",
    "wrong_reading_lock_refs",
    "created_at_utc"
  ],
  "title": "ProductHandoffEnvelope",
  "type": "object"
}
