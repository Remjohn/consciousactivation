{
  "$id": "urn:conscious-activations:activative-production-spine:0.1.0-dev.1:receipt-envelope",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable command outcome receipt.",
  "properties": {
    "authority": {
      "$ref": "authority-ref.schema.json"
    },
    "command_ref": {
      "$ref": "immutable-ref.schema.json"
    },
    "evaluator": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "actor-ref.schema.json"
        }
      ]
    },
    "failure": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "typed-failure.schema.json"
        }
      ]
    },
    "outcome": {
      "enum": [
        "accepted",
        "denied",
        "cancelled",
        "failed"
      ],
      "type": "string"
    },
    "receipt_id": {
      "minLength": 1,
      "type": "string"
    },
    "receipt_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "recorded_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "result_refs": {
      "items": {
        "$ref": "immutable-ref.schema.json"
      },
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "receipt_id",
    "command_ref",
    "outcome",
    "result_refs",
    "failure",
    "authority",
    "evaluator",
    "recorded_at_utc",
    "receipt_sha256"
  ],
  "title": "ReceiptEnvelope",
  "type": "object"
}
