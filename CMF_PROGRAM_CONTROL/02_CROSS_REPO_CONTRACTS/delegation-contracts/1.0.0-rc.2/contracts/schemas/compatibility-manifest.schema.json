{
  "$defs": {
    "AuthorityClaim": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "maxLength": 96,
          "minLength": 1,
          "type": "string"
        },
        "field_scopes": {
          "items": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "principal": {
          "$ref": "#/$defs/PrincipalRef"
        }
      },
      "required": [
        "action",
        "principal",
        "field_scopes"
      ],
      "type": "object"
    },
    "BoundingBoxBasisPoints": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "width": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "x": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        },
        "y": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "type": "object"
    },
    "ChangeItem": {
      "additionalProperties": false,
      "properties": {
        "operation": {
          "enum": [
            "ADD",
            "REMOVE",
            "REPLACE"
          ],
          "type": "string"
        },
        "path": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
          "type": "string"
        },
        "reason": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "value_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceIdentityRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "path",
        "operation",
        "value_ref",
        "reason"
      ],
      "type": "object"
    },
    "DemandIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "request_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "request_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "EvidenceFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/ResourceIdentityRef"
          },
          "minItems": 1,
          "type": "array"
        },
        "note": {
          "anyOf": [
            {
              "maxLength": 1024,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "verdict": {
          "enum": [
            "PASS",
            "CONCERNS",
            "FAIL"
          ],
          "type": "string"
        }
      },
      "required": [
        "code",
        "verdict",
        "evidence_refs",
        "note"
      ],
      "type": "object"
    },
    "ExecutionIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "demand": {
          "$ref": "#/$defs/DemandIdentityRef"
        },
        "execution_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "plan_ref": {
          "$ref": "#/$defs/ResourceIdentityRef"
        }
      },
      "required": [
        "execution_id",
        "demand",
        "plan_ref"
      ],
      "type": "object"
    },
    "FailureSummary": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "VALIDATION",
            "AUTHORITY",
            "COMPATIBILITY",
            "BUDGET",
            "EXECUTION",
            "INTEGRITY",
            "LIFECYCLE",
            "CAPABILITY",
            "HUMAN_REVIEW",
            "SECURITY"
          ],
          "type": "string"
        },
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "type": "string"
        },
        "field_paths": {
          "items": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "message": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message",
        "retryable",
        "field_paths"
      ],
      "type": "object"
    },
    "IntegrityProof": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "Ed25519",
          "type": "string"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "issued_at": {
          "format": "date-time",
          "type": "string"
        },
        "key_id": {
          "format": "uri",
          "type": "string"
        },
        "nonce": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "signature": {
          "pattern": "^[A-Za-z0-9_-]{86}$",
          "type": "string"
        },
        "signer": {
          "$ref": "#/$defs/PrincipalRef"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "signer",
        "signature",
        "issued_at",
        "expires_at",
        "nonce"
      ],
      "type": "object"
    },
    "MoneyAmount": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "type": "string"
        },
        "minor_units": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "currency",
        "minor_units"
      ],
      "type": "object"
    },
    "PrincipalRef": {
      "additionalProperties": false,
      "properties": {
        "principal_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "principal_type": {
          "enum": [
            "CONTENT_HARNESS",
            "DELEGATION_PROTOCOL",
            "VISUAL_ASSET_EDITOR",
            "CONTROL_TOWER"
          ],
          "type": "string"
        },
        "product_version": {
          "pattern": "^[0-9]+\\.[0-9]+$",
          "type": "string"
        }
      },
      "required": [
        "principal_id",
        "principal_type",
        "product_version"
      ],
      "type": "object"
    },
    "ResourceIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "resource_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "resource_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "ResultIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "result_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "result_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "State": {
      "enum": [
        "DRAFT",
        "SUBMITTED",
        "REJECTED",
        "ACCEPTED",
        "IN_PROGRESS",
        "RESULT_READY",
        "RESULT_REJECTED",
        "COMPLETED",
        "AMENDMENT_REQUIRED",
        "SUPERSEDED",
        "COST_APPROVAL_REQUIRED",
        "CAPABILITY_GAP",
        "HUMAN_REVIEW_REQUIRED",
        "CANCELLATION_REQUESTED",
        "CANCELLED",
        "PARTIAL_RESULT_READY",
        "INVALIDATED",
        "REVOKED",
        "REPLACED"
      ],
      "type": "string"
    }
  },
  "$id": "https://contracts.cmf.dev/delegation/compatibility-manifest/1.0/schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "CMF delegation protocol compatibility-manifest message.",
  "properties": {
    "features": {
      "items": {
        "pattern": "^[a-z][a-z0-9._-]{2,95}$",
        "type": "string",
        "x-cmf-value-owner": "SIGNING_PRINCIPAL"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true,
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "manifest_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "type": "string",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "message_versions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "message_type": {
            "pattern": "^[a-z][a-z0-9-]{2,63}$",
            "type": "string",
            "x-cmf-value-owner": "SIGNING_PRINCIPAL"
          },
          "version": {
            "pattern": "^[0-9]+\\.[0-9]+$",
            "type": "string",
            "x-cmf-value-owner": "SIGNING_PRINCIPAL"
          }
        },
        "required": [
          "message_type",
          "version"
        ],
        "type": "object",
        "x-cmf-value-owner": "SIGNING_PRINCIPAL"
      },
      "minItems": 1,
      "type": "array",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "package_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
      "type": "string",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "protocol_versions": {
      "items": {
        "pattern": "^[0-9]+\\.[0-9]+$",
        "type": "string",
        "x-cmf-value-owner": "SIGNING_PRINCIPAL"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true,
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "published_at": {
      "format": "date-time",
      "type": "string",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "required_signature_algorithms": {
      "items": {
        "enum": [
          "Ed25519"
        ],
        "type": "string",
        "x-cmf-value-owner": "SIGNING_PRINCIPAL"
      },
      "minItems": 1,
      "type": "array",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    },
    "status": {
      "enum": [
        "RELEASE_CANDIDATE",
        "PUBLISHED",
        "DEPRECATED",
        "REVOKED"
      ],
      "type": "string",
      "x-cmf-value-owner": "SIGNING_PRINCIPAL"
    }
  },
  "required": [
    "manifest_id",
    "package_version",
    "protocol_versions",
    "message_versions",
    "features",
    "required_signature_algorithms",
    "status",
    "published_at"
  ],
  "title": "Compatibility Manifest",
  "type": "object",
  "x-cmf-authority": {
    "allowed_producers": [
      "CONTENT_HARNESS",
      "DELEGATION_PROTOCOL",
      "VISUAL_ASSET_EDITOR",
      "CONTROL_TOWER"
    ],
    "path_kind": "JSON_POINTER_TEMPLATE",
    "value_owner_by_path": {
      "/features": "SIGNING_PRINCIPAL",
      "/features/{index}": "SIGNING_PRINCIPAL",
      "/manifest_id": "SIGNING_PRINCIPAL",
      "/message_versions": "SIGNING_PRINCIPAL",
      "/message_versions/{index}": "SIGNING_PRINCIPAL",
      "/message_versions/{index}/message_type": "SIGNING_PRINCIPAL",
      "/message_versions/{index}/version": "SIGNING_PRINCIPAL",
      "/package_version": "SIGNING_PRINCIPAL",
      "/protocol_versions": "SIGNING_PRINCIPAL",
      "/protocol_versions/{index}": "SIGNING_PRINCIPAL",
      "/published_at": "SIGNING_PRINCIPAL",
      "/required_signature_algorithms": "SIGNING_PRINCIPAL",
      "/required_signature_algorithms/{index}": "SIGNING_PRINCIPAL",
      "/status": "SIGNING_PRINCIPAL"
    }
  },
  "x-cmf-consumers": [
    "CONTENT_HARNESS",
    "DELEGATION_PROTOCOL",
    "VISUAL_ASSET_EDITOR",
    "CONTROL_TOWER"
  ],
  "x-cmf-idempotency": "PROHIBITED",
  "x-cmf-lifecycle-effects": [
    "compatibility_manifest_published"
  ],
  "x-cmf-message-type": "compatibility-manifest",
  "x-cmf-message-version": "1.0"
}
