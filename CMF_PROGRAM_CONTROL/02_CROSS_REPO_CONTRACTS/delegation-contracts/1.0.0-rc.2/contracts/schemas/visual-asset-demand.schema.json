          "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
          "type": "string"
        },
        "reason": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "value_ref": {
          "anyOf": [
