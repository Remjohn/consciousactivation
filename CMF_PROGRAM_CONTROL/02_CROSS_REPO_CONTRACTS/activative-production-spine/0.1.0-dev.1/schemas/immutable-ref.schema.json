{
  "$id": "urn:conscious-activations:activative-production-spine:0.1.0-dev.1:immutable-ref",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable content-addressed reference shared by Conscious Activations products.",
  "properties": {
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "version": {
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$",
      "type": "string"
    }
  },
  "required": [
    "object_id",
    "version",
    "sha256"
  ],
  "title": "ImmutableRef",
  "type": "object"
}
