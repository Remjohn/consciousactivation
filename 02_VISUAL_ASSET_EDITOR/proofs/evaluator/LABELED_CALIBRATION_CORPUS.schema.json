{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmf://vae/readiness/labeled-calibration-corpus/1.0",
  "title": "Labeled Calibration Corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["classification", "corpus_id", "version", "profile_ref", "status", "labeling_authority_status", "cases"],
  "properties": {
    "classification": {"const": "non_production_readiness_proof"},
    "corpus_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "profile_ref": {"type": "string", "minLength": 1},
    "status": {"enum": ["provisional_seed", "adjudicated_calibration", "retired"]},
    "labeling_authority_status": {"enum": ["not_reviewed", "review_in_progress", "approved"]},
    "cases": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "asset_ref", "source_kind", "provenance_ref", "scenario_summary", "coverage_tags", "labels"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^CAL-F02-"},
          "asset_ref": {"type": "string", "minLength": 1},
          "source_kind": {"enum": ["controlled_synthetic_fixture", "accepted_reference_asset", "governed_external_asset"]},
          "provenance_ref": {"type": "string", "minLength": 1},
          "scenario_summary": {"type": "string", "minLength": 1},
          "coverage_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "labels": {
            "type": "object",
            "additionalProperties": false,
            "required": ["overall_verdict", "responsible_layer", "repairability", "dimension_labels", "wrong_reading_lock_violation", "no_text_result", "recurrence_result"],
            "properties": {
              "overall_verdict": {"enum": ["accept", "repair", "reject", "human_review"]},
              "responsible_layer": {"enum": ["none", "activative_lineage", "activation_contract", "visual_semantics", "visual_narrative", "feature_contract", "somatic_route", "composition_intent", "materialization", "materialization_pose_conditioning", "technical", "identity_continuity", "temporal", "evaluation_infrastructure"]},
              "repairability": {"enum": ["repairable_vae_binding", "upstream_amendment_required", "infrastructure_retry", "non_repairable", "not_applicable"]},
              "dimension_labels": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["clear_pass", "borderline", "clear_fail", "not_applicable", "uncertain"]}},
              "wrong_reading_lock_violation": {"type": "boolean"},
              "no_text_result": {"enum": ["pass", "fail", "not_applicable", "not_run"]},
              "recurrence_result": {"enum": ["beneficial", "redundant", "contradictory", "not_applicable"]}
            }
          }
        }
      }
    }
  }
}
