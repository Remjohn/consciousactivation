    },
    "constitution_version": {
      "minLength": 1,
      "type": "string"
    },
    "issued_by": {
      "minLength": 1,
      "type": "string"
    },
    "product_authorities": {
      "type": "array"
    },
    "schema_id": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "minLength": 1,
      "type": "string"
    },
    "snapshot_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "snapshot_id",
    "constitution_id",
    "constitution_version",
    "constitution_sha256",
    "product_authorities",
