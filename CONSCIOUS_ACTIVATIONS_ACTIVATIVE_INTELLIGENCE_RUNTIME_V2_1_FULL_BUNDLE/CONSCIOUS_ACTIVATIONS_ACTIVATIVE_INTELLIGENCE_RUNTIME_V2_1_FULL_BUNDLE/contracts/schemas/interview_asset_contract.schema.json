{
  "$defs": {
    "FollowUpBranch": {
      "additionalProperties": false,
      "properties": {
        "branch_id": {
          "title": "Branch Id",
          "type": "string"
        },
        "condition": {
          "title": "Condition",
          "type": "string"
        },
        "pressure_delta": {
          "maximum": 2,
          "minimum": -2,
          "title": "Pressure Delta",
          "type": "integer"
        },
        "question": {
          "title": "Question",
          "type": "string"
        },
        "stop_after": {
          "default": false,
          "title": "Stop After",
          "type": "boolean"
        },
        "target_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/NarrativeState"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "branch_id",
        "condition",
        "question",
        "pressure_delta"
      ],
      "title": "FollowUpBranch",
      "type": "object"
    },
    "ImmutableRef": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "title": "Object Id",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "title": "ImmutableRef",
      "type": "object"
    },
    "NarrativeState": {
      "enum": [
