{
  "$defs": {
    "ApplicabilityEnvelope": {
      "additionalProperties": false,
      "properties": {
        "audience_segments": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Audience Segments",
          "type": "array"
        },
        "coach_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Coach Ids",
          "type": "array"
        },
        "exclusions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Exclusions",
          "type": "array"
        },
        "formats": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Formats",
          "type": "array"
        },
        "platforms": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Platforms",
          "type": "array"
        },
        "pressure_domains": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Pressure Domains",
          "type": "array"
        },
        "relationship_stages": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Relationship Stages",
          "type": "array"
        }
      },
      "title": "ApplicabilityEnvelope",
      "type": "object"
    },
    "EpistemicState": {
      "enum": [
        "planned",
        "observed",
        "inferred",
        "operator_confirmed",
        "rejected",
        "superseded"
      ],
      "title": "EpistemicState",
      "type": "string"
    },
    "ImmutableRef": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "title": "Object Id",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "title": "ImmutableRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "applicability": {
      "$ref": "#/$defs/ApplicabilityEnvelope"
    },
    "audience_fit": {
      "maximum": 1,
      "minimum": 0,
      "title": "Audience Fit",
      "type": "number"
    },
    "coach_fit": {
      "maximum": 1,
      "minimum": 0,
      "title": "Coach Fit",
      "type": "number"
    },
    "coach_id": {
      "title": "Coach Id",
      "type": "string"
    },
    "contradictions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Contradictions",
      "type": "array"
    },
    "epistemic_state": {
      "$ref": "#/$defs/EpistemicState"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/ImmutableRef"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "observation_id": {
      "title": "Observation Id",
      "type": "string"
    },
    "profile_resolution_status": {
      "default": "pending",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "superseded"
      ],
      "title": "Profile Resolution Status",
      "type": "string"
    },
    "proposed_dimension": {
      "enum": [
        "identity_role",
        "stance",
        "edge",
        "emotional_range",
        "visual_world",
        "negative_space",
        "lived_proof"
      ],
      "title": "Proposed Dimension",
      "type": "string"
    },
    "proposed_value": {
      "title": "Proposed Value",
      "type": "string"
    },
    "recurrence_count": {
      "minimum": 1,
      "title": "Recurrence Count",
      "type": "integer"
    }
  },
  "required": [
    "observation_id",
    "coach_id",
    "proposed_dimension",
    "proposed_value",
    "epistemic_state",
    "evidence_refs",
    "recurrence_count",
    "coach_fit",
    "audience_fit",
    "applicability"
  ],
  "title": "IdentityDNACandidateObservation",
  "type": "object"
}
