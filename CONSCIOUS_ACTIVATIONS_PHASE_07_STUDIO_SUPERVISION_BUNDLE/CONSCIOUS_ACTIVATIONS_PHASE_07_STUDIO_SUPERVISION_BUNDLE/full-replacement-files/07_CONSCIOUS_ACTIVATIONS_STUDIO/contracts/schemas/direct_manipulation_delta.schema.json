{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "arguments": {
      "type": "object"
    },
    "current_state_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "delta_id": {
      "minLength": 1,
      "type": "string"
    },
    "expected_state_version": {
      "minimum": 1,
      "type": "integer"
    },
    "manipulation_type": {
      "enum": [
        "MOVE_BBOX",
        "RESIZE_BBOX",
        "TRIM_SEGMENT",
        "REORDER_ITEM",
        "EDIT_TEXT",
        "SET_PARAMETER",
        "SELECT_CANDIDATE"
      ],
      "type": "string"
    },
    "operator_actor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "type": "string"
        },
        "actor_type": {
          "enum": [
            "deterministic_module",
            "model_program",
            "human"
          ],
          "type": "string"
        },
        "product_id": {
          "minLength": 1,
          "type": "string"
        },
        "workflow_role": {
          "enum": [
            "hunter",
            "analyst",
            "composer",
            "commander",
            "evaluator",
            "operator"
          ],
          "type": "string"
        }
      },
      "required": [
        "actor_id",
        "actor_type",
        "product_id",
        "workflow_role"
      ],
      "type": "object"
    },
    "run_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "target_node_id": {
      "minLength": 1,
      "type": "string"
    },
    "target_ref": {
      "additionalProperties": false,
      "properties": {
        "object_id": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "version",
        "sha256"
      ],
      "type": "object"
    }
  },
  "required": [
    "delta_id",
    "run_ref",
    "target_ref",
    "target_node_id",
    "manipulation_type",
    "arguments",
    "current_state_ref",
    "operator_actor",
    "expected_state_version"
  ],
  "title": "DirectManipulationDelta",
  "type": "object"
}
