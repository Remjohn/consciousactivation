          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "resource_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        }
      },
      "required": [
        "resource_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object",
      "x-cmf-value-owner": "DELEGATION_PROTOCOL"
    },
    "ResultIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
