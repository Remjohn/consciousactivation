    "IntegrityProof": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "Ed25519",
          "type": "string"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
