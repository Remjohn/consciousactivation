{
  "$defs": {
    "AuthorityClaim": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "maxLength": 96,
          "minLength": 1,
          "type": "string"
        },
        "field_scopes": {
          "items": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "principal": {
          "$ref": "#/$defs/PrincipalRef"
        }
      },
      "required": [
        "action",
        "principal",
        "field_scopes"
      ],
      "type": "object"
    },
    "BoundingBoxBasisPoints": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "width": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "x": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        },
        "y": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "type": "object"
    },
    "ChangeItem": {
      "additionalProperties": false,
      "properties": {
        "operation": {
          "enum": [
            "ADD",
            "REMOVE",
            "REPLACE"
          ],
          "type": "string"
        },
        "path": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
          "type": "string"
        },
        "reason": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "value_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceIdentityRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "path",
        "operation",
        "value_ref",
        "reason"
      ],
      "type": "object"
    },
    "DemandIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "request_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "DELEGATION_PROTOCOL"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "request_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "EvidenceFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/ResourceIdentityRef"
          },
          "minItems": 1,
          "type": "array"
        },
        "note": {
