      "/sender/principal_type": "SIGNING_PRINCIPAL",
      "/sender/product_version": "SIGNING_PRINCIPAL"
    }
  },
  "x-cmf-consumers": [
    "CONTENT_HARNESS",
    "DELEGATION_PROTOCOL",
    "VISUAL_ASSET_EDITOR",
    "CONTROL_TOWER"
  ],
  "x-cmf-idempotency": "CONDITIONAL",
  "x-cmf-lifecycle-effects": [],
  "x-cmf-message-type": "delegation-envelope",
  "x-cmf-message-version": "1.0"
