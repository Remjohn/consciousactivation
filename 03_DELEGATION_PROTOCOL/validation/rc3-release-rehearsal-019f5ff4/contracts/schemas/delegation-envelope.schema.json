      "/authority/principal": "SIGNING_PRINCIPAL",
      "/authority/principal/principal_id": "SIGNING_PRINCIPAL",
      "/authority/principal/principal_type": "SIGNING_PRINCIPAL",
      "/authority/principal/product_version": "SIGNING_PRINCIPAL",
      "/causation_id": "SIGNING_PRINCIPAL",
