      "/occurred_at": "SIGNING_PRINCIPAL",
      "/payload_hash": "SIGNING_PRINCIPAL",
      "/payload_ref": "SIGNING_PRINCIPAL",
      "/protocol_version": "SIGNING_PRINCIPAL",
      "/recipient": "SIGNING_PRINCIPAL",
      "/recipient/principal_id": "SIGNING_PRINCIPAL",
