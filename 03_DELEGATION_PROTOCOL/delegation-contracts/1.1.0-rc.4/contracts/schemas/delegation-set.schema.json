{
  "$defs": {
    "AuthorityClaim": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "maxLength": 96,
          "minLength": 1,
          "type": "string"
        },
        "field_scopes": {
          "items": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "principal": {
          "$ref": "#/$defs/PrincipalRef"
        }
      },
      "required": [
        "action",
        "principal",
        "field_scopes"
      ],
      "type": "object"
    },
    "BoundingBoxBasisPoints": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "width": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "x": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        },
        "y": {
          "maximum": 10000,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "type": "object"
    },
    "ChangeItem": {
      "additionalProperties": false,
      "properties": {
        "operation": {
          "enum": [
            "ADD",
            "REMOVE",
            "REPLACE"
          ],
          "type": "string"
        },
        "path": {
          "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
          "type": "string"
        },
        "reason": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "value_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceIdentityRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "path",
        "operation",
        "value_ref",
        "reason"
      ],
      "type": "object"
    },
    "DemandIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "request_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "version": {
          "minimum": 1,
          "type": "integer",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        }
      },
      "required": [
        "request_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "EvidenceFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/ResourceIdentityRef"
          },
          "minItems": 1,
          "type": "array"
        },
        "note": {
          "anyOf": [
            {
              "maxLength": 1024,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "verdict": {
          "enum": [
            "PASS",
            "CONCERNS",
            "FAIL"
          ],
          "type": "string"
        }
      },
      "required": [
        "code",
        "verdict",
        "evidence_refs",
        "note"
      ],
      "type": "object"
    },
    "ExecutionIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "demand": {
          "$ref": "#/$defs/DemandIdentityRef"
        },
        "execution_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "plan_ref": {
          "$ref": "#/$defs/ResourceIdentityRef"
        }
      },
      "required": [
        "execution_id",
        "demand",
        "plan_ref"
      ],
      "type": "object"
    },
    "FailureSummary": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "VALIDATION",
            "AUTHORITY",
            "COMPATIBILITY",
            "BUDGET",
            "EXECUTION",
            "INTEGRITY",
            "LIFECYCLE",
            "CAPABILITY",
            "HUMAN_REVIEW",
            "SECURITY"
          ],
          "type": "string"
        },
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]{2,63}$",
          "type": "string"
        },
        "field_paths": {
          "items": {
            "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$",
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "message": {
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message",
        "retryable",
        "field_paths"
      ],
      "type": "object"
    },
    "IntegrityProof": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "Ed25519",
          "type": "string"
        },
        "expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "issued_at": {
          "format": "date-time",
          "type": "string"
        },
        "key_id": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "nonce": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "signature": {
          "pattern": "^[A-Za-z0-9_-]{86}$",
          "type": "string"
        },
        "signer": {
          "$ref": "#/$defs/PrincipalRef"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "signer",
        "signature",
        "issued_at",
        "expires_at",
        "nonce"
      ],
      "type": "object"
    },
    "MoneyAmount": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "type": "string"
        },
        "minor_units": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "currency",
        "minor_units"
      ],
      "type": "object"
    },
    "PrincipalRef": {
      "additionalProperties": false,
      "properties": {
        "principal_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "principal_type": {
          "enum": [
            "CONTENT_HARNESS",
            "DELEGATION_PROTOCOL",
            "VISUAL_ASSET_EDITOR",
            "CONTROL_TOWER"
          ],
          "type": "string"
        },
        "product_version": {
          "pattern": "^[0-9]+\\.[0-9]+$",
          "type": "string"
        }
      },
      "required": [
        "principal_id",
        "principal_type",
        "product_version"
      ],
      "type": "object"
    },
    "ResourceIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "resource_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "version": {
          "maxLength": 64,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "resource_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "ResultIdentityRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_ref": {
          "format": "uri",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "payload_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "result_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
          "type": "string",
          "x-cmf-value-owner": "CONTENT_HARNESS"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "result_id",
        "version",
        "payload_hash",
        "canonical_ref"
      ],
      "type": "object"
    },
    "State": {
      "enum": [
        "DRAFT",
        "SUBMITTED",
        "REJECTED",
        "ACCEPTED",
        "IN_PROGRESS",
        "RESULT_READY",
        "RESULT_REJECTED",
        "COMPLETED",
        "AMENDMENT_REQUIRED",
        "SUPERSEDED",
        "COST_APPROVAL_REQUIRED",
        "CAPABILITY_GAP",
        "HUMAN_REVIEW_REQUIRED",
        "CANCELLATION_REQUESTED",
        "CANCELLED",
        "PARTIAL_RESULT_READY",
        "INVALIDATED",
        "REVOKED",
        "REPLACED"
      ],
      "type": "string"
    }
  },
  "$id": "https://contracts.cmf.dev/delegation/delegation-set/1.0/schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "CMF delegation protocol delegation-set message.",
  "properties": {
    "completion_policy": {
      "enum": [
        "ALL",
        "MINIMUM_COUNT",
        "NAMED_MEMBERS"
      ],
      "type": "string",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "dependency_edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "REQUIRES",
              "ORDER_BEFORE",
              "SHARES_IDENTITY"
            ],
            "type": "string",
            "x-cmf-value-owner": "CONTENT_HARNESS"
          },
          "predecessor": {
            "$ref": "#/$defs/DemandIdentityRef",
            "x-cmf-value-owner": "CONTENT_HARNESS"
          },
          "successor": {
            "$ref": "#/$defs/DemandIdentityRef",
            "x-cmf-value-owner": "CONTENT_HARNESS"
          }
        },
        "required": [
          "predecessor",
          "successor",
          "kind"
        ],
        "type": "object",
        "x-cmf-value-owner": "CONTENT_HARNESS"
      },
      "type": "array",
      "uniqueItems": true,
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "failure_policy": {
      "enum": [
        "FAIL_FAST",
        "CONTINUE_INDEPENDENT",
        "PAUSE_DEPENDENTS"
      ],
      "type": "string",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "member_demands": {
      "items": {
        "$ref": "#/$defs/DemandIdentityRef",
        "x-cmf-value-owner": "CONTENT_HARNESS"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true,
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "minimum_completed": {
      "minimum": 1,
      "type": "integer",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "set_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
      "type": "string",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    },
    "version": {
      "minimum": 1,
      "type": "integer",
      "x-cmf-value-owner": "CONTENT_HARNESS"
    }
  },
  "required": [
    "set_id",
    "version",
    "member_demands",
    "dependency_edges",
    "completion_policy",
    "minimum_completed",
    "failure_policy"
  ],
  "title": "Delegation Set",
  "type": "object",
  "x-cmf-authority": {
    "allowed_producers": [
      "CONTENT_HARNESS"
    ],
    "path_kind": "JSON_POINTER_TEMPLATE",
    "value_owner_by_path": {
      "/completion_policy": "CONTENT_HARNESS",
      "/dependency_edges": "CONTENT_HARNESS",
      "/dependency_edges/{index}": "CONTENT_HARNESS",
      "/dependency_edges/{index}/kind": "CONTENT_HARNESS",
      "/dependency_edges/{index}/predecessor": "CONTENT_HARNESS",
      "/dependency_edges/{index}/predecessor/canonical_ref": "CONTENT_HARNESS",
      "/dependency_edges/{index}/predecessor/payload_hash": "CONTENT_HARNESS",
      "/dependency_edges/{index}/predecessor/request_id": "CONTENT_HARNESS",
      "/dependency_edges/{index}/predecessor/version": "CONTENT_HARNESS",
      "/dependency_edges/{index}/successor": "CONTENT_HARNESS",
      "/dependency_edges/{index}/successor/canonical_ref": "CONTENT_HARNESS",
      "/dependency_edges/{index}/successor/payload_hash": "CONTENT_HARNESS",
      "/dependency_edges/{index}/successor/request_id": "CONTENT_HARNESS",
      "/dependency_edges/{index}/successor/version": "CONTENT_HARNESS",
      "/failure_policy": "CONTENT_HARNESS",
      "/member_demands": "CONTENT_HARNESS",
      "/member_demands/{index}": "CONTENT_HARNESS",
      "/member_demands/{index}/canonical_ref": "CONTENT_HARNESS",
      "/member_demands/{index}/payload_hash": "CONTENT_HARNESS",
      "/member_demands/{index}/request_id": "CONTENT_HARNESS",
      "/member_demands/{index}/version": "CONTENT_HARNESS",
      "/minimum_completed": "CONTENT_HARNESS",
      "/set_id": "CONTENT_HARNESS",
      "/version": "CONTENT_HARNESS"
    }
  },
  "x-cmf-consumers": [
    "DELEGATION_PROTOCOL",
    "VISUAL_ASSET_EDITOR",
    "CONTROL_TOWER"
  ],
  "x-cmf-idempotency": "REQUIRED",
  "x-cmf-lifecycle-effects": [
    "delegation_set_recorded"
  ],
  "x-cmf-message-type": "delegation-set",
  "x-cmf-message-version": "1.0"
}
