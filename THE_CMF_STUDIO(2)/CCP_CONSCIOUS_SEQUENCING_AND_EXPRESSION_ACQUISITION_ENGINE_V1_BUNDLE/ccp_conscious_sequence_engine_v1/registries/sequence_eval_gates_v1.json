{
  "schema_version": "1.0.0",
  "registry_id": "sequence_eval_gates_v1",
  "gates": [
    {
      "id": "INTERVIEW_BRIEF_PROCUREMENT_READY",
      "scope": "pre_interview",
      "hard": true,
      "checks": [
        "brand_context_pinned",
        "asset_portfolio_declared",
        "sequence_hypotheses_present",
        "required_ingredients_have_instruments",
        "safety_territories_identified"
      ]
    },
    {
      "id": "LIVE_CUE_STATE_SAFE",
      "scope": "live",
      "hard": true,
      "checks": [
        "not_emotional_peak",
        "guest_comfort_ok",
        "sensitive_followup_confirmed",
        "cue_not_redundant"
      ]
    },
    {
      "id": "INGREDIENT_SOURCE_INTEGRITY",
      "scope": "inventory",
      "hard": true,
      "checks": [
        "source_present",
        "timestamps_valid",
        "speaker_known",
        "quotation_undistorted",
        "hash_present"
      ]
    },
    {
      "id": "SEQUENCE_LOOP_CLOSURE",
      "scope": "asset_sequence",
      "hard": true,
      "checks": [
        "all_must_close_loops_closed",
        "payoff_source_grounded",
        "discussion_open_explicit"
      ]
    },
    {
      "id": "SEQUENCE_PROGRESSIVE_DISCLOSURE",
      "scope": "asset_sequence",
      "hard": false,
      "checks": [
        "clues_coherent",
        "confusion_below_threshold",
        "no_random_detail_dump"
      ]
    },
    {
      "id": "VOICE_DNA_AND_NEGATIVE_SPACE",
      "scope": "asset_sequence",
      "hard": true,
      "checks": [
        "voice_dna_pass",
        "negative_space_pass",
        "no_synthetic_sheen"
      ]
    },
    {
      "id": "ETHICAL_EARNED_ATTENTION",
      "scope": "asset_sequence",
      "hard": true,
      "checks": [
        "no_false_hook",
        "no_fabricated_conflict",
        "no_trauma_bait",
        "no_guest_meaning_distortion"
      ]
    },
    {
      "id": "PACKAGE_RELATIONSHIP_PROGRESSION",
      "scope": "package",
      "hard": false,
      "checks": [
        "humanity_present",
        "concrete_value_present",
        "differentiation_present",
        "participation_present",
        "future_value_coherent"
      ]
    }
  ]
}