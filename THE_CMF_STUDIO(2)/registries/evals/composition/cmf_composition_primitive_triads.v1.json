{
  "schema_version": "cmf.composition_primitive_triads.v1",
  "registry_id": "CMF-COMP-PRIMITIVE-TRIADS-001",
  "name": "CMF Composition Primitive Triads",
  "purpose": "Machine-loadable route rules that block any visual composition, prompt, JSON template, preview, renderer template, or approval asset from advancing unless it passes at least three primitive validations.",
  "status": "active",
  "minimum_validated_primitives": 3,
  "required_roles": [
    "meaning_transform",
    "delivery_shape",
    "format_material"
  ],
  "applies_to": [
    "VisualFeelContract",
    "SceneSpec",
    "CompositionPlan",
    "CompositionJob",
    "IdeogramCompositionJSON",
    "PreviewKeyframe",
    "MotionTemplate",
    "RendererTemplate",
    "ApprovalPreview"
  ],
  "source_doctrine_refs": [
    "THE CMF STUDIO/product-brief-CMF_STUDIO-2026-06-19.md",
    "THE CMF STUDIO/Matrix of Edging.md",
    "THE CMF STUDIO/CCP V9 — Interview-First Expression Engine.md",
    "THE CMF STUDIO/CCP V9.1 — Expression Capture & Archetype Routing Update.md",
    "THE CMF STUDIO/CCP_CMF_Brand_Genesis_and_Micro_Semiotic_Pipeline_V3.md",
    "THE CMF STUDIO/CCP_Creative_Pipeline_Architecture_V2.md",
    "THE CMF STUDIO/docs/tech-specs/TS-CMF-077-doctrine-driven-test-harness-and-primitive-eval-coverage.md",
    "THE CMF STUDIO/docs/tech-specs/TS-CMF-078-four-video-format-runtime-and-doctrine-crosswalk.md",
    "THE CMF STUDIO/docs/tech-specs/TS-CMF-079-route-specific-visual-feel-and-primitive-composition-gates.md"
  ],
  "global_validation_dimensions": [
    "primitive_declared_with_exact_id",
    "primitive_role_is_explicit",
    "evidence_ref_is_present",
    "route_fit_is_explained",
    "composition_element_activates_primitive",
    "primitive_score_meets_threshold",
    "primitive_coalition_avoids_style_flattening"
  ],
  "hard_failure_codes": [
    "COMPOSITION_PRIMITIVE_MINIMUM_NOT_MET",
    "COMPOSITION_PRIMITIVE_ROLE_COVERAGE_MISSING",
    "COMPOSITION_PRIMITIVE_EVIDENCE_MISSING",
    "COMPOSITION_PRIMITIVE_SCORE_BELOW_THRESHOLD",
    "COMPOSITION_PRIMITIVE_ID_NOT_REGISTERED",
    "COMPOSITION_ROUTE_FEEL_COLLAPSED",
    "COMPOSITION_GENERIC_PREMIUM_SOCIAL_SLOP",
    "COMPOSITION_DOCTRINE_CONFLICT"
  ],
  "primitive_reference_policy": {
    "registered_primitive_required": true,
    "accepted_registry_roots": [
      "THE CMF STUDIO/registries/primitives/meaning_plane",
      "THE CMF STUDIO/registries/primitives/experience_plane"
    ],
    "accepted_supporting_refs": [
      "MATRIX.IRONY_INVERSION",
      "MATRIX.WHAT_IS_WHAT_COULD_BE",
      "MATRIX.ANALOGY_BRIDGE",
      "MATRIX.STAKES_AS_PERSONAL_WHY"
    ],
    "supporting_refs_count_toward_minimum": false,
    "note": "Matrix refs may explain pressure selection, but the minimum three validation count must be satisfied by registered primitive IDs."
  },
  "role_definitions": {
    "meaning_transform": "The primitive that explains what meaning operation the composition performs: inversion, analogy, backstory, recognition, contrast, proof, or stakes.",
    "delivery_shape": "The primitive that explains how the audience is guided through the meaning: tension, explanation, story beat, social proof, audience matching, rule of three, or sensory anchoring.",
    "format_material": "The primitive that explains why the composition should look and move this way: paper layer materiality, cinematic light, eye path, frame behavior, playback context, controlled density, or human proof surface."
  },
  "route_triads": {
