  "receipt_contract": {
    "receipt_type": "CompositionPreflightReceipt",
    "required_fields": [
      "composition_id",
      "route_id",
      "visual_feel_contract_id",
      "minimum_validated_primitives",
      "primitive_validation_count",
      "primitive_results",
      "role_coverage",
      "hard_failure_codes",
      "decision"
    ],
    "primitive_result_fields": [
      "primitive_id",
      "primitive_name",
      "role",
      "score",
      "threshold",
      "evidence_ref",
      "composition_element_ref",
      "decision"
    ],
    "approval_policy": {
      "pass_requires": [
        "primitive_validation_count >= 3",
        "role_coverage.meaning_transform == true",
        "role_coverage.delivery_shape == true",
        "role_coverage.format_material == true",
        "all_required_primitive_scores_meet_threshold",
        "no_hard_failure_codes"
      ],
      "block_decisions": [
        "BLOCKED_FOR_PRIMITIVE_MINIMUM",
        "BLOCKED_FOR_ROLE_COVERAGE",
        "BLOCKED_FOR_EVIDENCE",
        "BLOCKED_FOR_ROUTE_FEEL_COLLAPSE"
