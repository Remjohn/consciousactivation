{
  "schema_version": "cmf.carousel_slide_composition_library.v1",
  "registry_id": "CMF-CAROUSEL-SLIDE-COMP-LIB-001",
  "name": "CMF Carousel Slide Composition Library",
  "status": "active-draft",
  "purpose": "Queryable library of carousel slide atoms. Each slide atom owns a specific composition meaning, primitive triad, visual grammar, geometry requirements, and sequence position policy.",
  "recognized_carousel_format_codes": [
    "CAR-LST",
    "CAR-JUX"
  ],
  "global_rules": {
    "minimum_validated_primitives": 3,
    "required_roles": [
      "meaning_transform",
      "delivery_shape",
      "format_material"
    ],
    "must_preserve_sequence_over_single_image": true,
    "must_use_grid_as_cognitive_relief": true,
    "must_emit_geometrics_layout_plan": true,
    "must_emit_skia_render_job": true,
    "forbidden_behaviors": [
      "same_layout_every_slide_without_sequence_reason",
      "decorative_image_without_composition_meaning",
      "text_dump_slide",
      "primitive_labels_without_exact_ids",
      "browser_screenshot_as_production_render",
      "newsletter_format"
    ]
  },
  "query_dimensions": [
    "format_code",
    "slide_atom_code",
    "composition_meaning",
    "allowed_position",
    "archetype_route",
    "primitive_id",
    "primitive_role",
    "visual_shot_type",
    "layout_density",
    "matrix_pressure",
    "audience_state",
    "brand_context_version_id",
    "source_expression_moment_id"
  ],
