          "dominant headline",
          "one punctum or symbolic object",
          "small guest or brand mark"
        ],
        "geometry_requirements": [
          "single dominant text block",
          "minimum 35 percent negative space",
          "one clear focal object or cutout",
          "no more than one secondary label"
