{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "DEP-VID-025",
  "title": "Pipeline State",
  "description": "FR-VID-09 §5 — Video lifecycle state machine tracking pipeline progress through 16 states. Includes state history, beat-level approvals, render URLs, cost tracking, and checkpoint path.",
  "type": "object",
  "required": ["pipeline_id", "video_id", "project_id", "beat_cluster_id", "current_state", "state_history", "beat_approvals"],
  "properties": {
    "pipeline_id": {
      "type": "string",
      "pattern": "^PIPE-\\d{8}-\\d{3}$"
    },
    "video_id": { "type": "string" },
    "project_id": { "type": "string" },
    "beat_cluster_id": { "type": "string" },
    "current_state": {
      "type": "string",
      "enum": [
        "PENDING", "GENERATING_T2I", "PROCESSING_AUDIO", "AUDIO_COMPLETE",
        "QUALITY_GATE", "GENERATING_I2V", "FINGERPRINTING",
        "ASSEMBLING_MANIFEST", "GENERATING_CAPTIONS", "RENDERING_PREVIEW",
        "READY_FOR_REVIEW", "REGENERATING", "RENDERING_FINAL",
        "APPROVED", "PUBLISHED", "FAILED"
      ]
    },
    "state_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state", "entered_at"],
        "properties": {
          "state": { "type": "string" },
          "entered_at": { "type": "string", "format": "date-time" },
          "metadata": { "type": "object" }
        }
      }
    },
    "beat_approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat_index", "status"],
        "properties": {
          "beat_index": { "type": "integer", "minimum": 0 },
          "status": {
            "type": "string",
            "enum": ["PENDING_REVIEW", "APPROVED", "REGENERATING", "REJECTED"]
          },
          "quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "regeneration_mode": {
            "type": ["string", "null"],
            "enum": ["T2I_ONLY", "I2V_ONLY", "BOTH", null]
          },
          "regeneration_count": { "type": "integer", "minimum": 0, "default": 0 }
        }
      }
    },
    "preview_render_url": { "type": ["string", "null"] },
    "final_render_url": { "type": ["string", "null"] },
    "total_generation_cost_usd": { "type": "number", "minimum": 0 },
    "total_regenerations": { "type": "integer", "minimum": 0 },
    "checkpoint_path": { "type": ["string", "null"] },
    "error": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
