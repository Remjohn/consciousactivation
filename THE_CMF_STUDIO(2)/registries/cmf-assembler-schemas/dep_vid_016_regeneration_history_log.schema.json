{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "DEP-VID-016",
  "title": "Regeneration History Log",
  "description": "FR-VID-05 §3 — Audit trail of all regeneration events for a beat. Entries are chronological and immutable once created.",
  "type": "object",
  "required": ["beat_index", "history"],
  "properties": {
    "beat_index": {
      "type": "integer",
      "minimum": 0
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["superseded_fingerprint_id", "superseded_at", "reason", "mode", "new_fingerprint_id"],
        "properties": {
          "superseded_fingerprint_id": {
            "type": "string",
            "description": "The fingerprint ID that was superseded."
          },
          "superseded_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of supersession."
          },
          "reason": {
            "type": "string",
            "description": "Operator's revision note."
          },
          "mode": {
            "type": "string",
            "enum": ["T2I_ONLY", "I2V_ONLY", "BOTH"]
          },
          "new_fingerprint_id": {
            "type": "string",
            "description": "The fingerprint ID that replaced the superseded one."
          }
        }
      }
    },
    "total_regenerations": {
      "type": "integer",
      "minimum": 0
    }
  }
}
