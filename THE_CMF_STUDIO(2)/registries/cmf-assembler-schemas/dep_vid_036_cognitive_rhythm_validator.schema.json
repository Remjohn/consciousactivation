{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DEP-VID-036 - Cognitive Rhythm Validator",
  "description": "Sequence-level validator spec for enforcing research-backed pacing, recovery, congruence, continuity, and peak-end rhythm in Scene Builder output.",
  "type": "object",
  "required": [
    "schema_id",
    "validator_id",
    "version",
    "compile_target",
    "runtime_stage",
    "sequence_contract",
    "gates",
    "score_bands"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "enum": ["cmf.cognitive.rhythm.validator/v1"]
    },
    "validator_id": { "type": "string" },
    "version": { "type": "string" },
    "compile_target": {
      "type": "string",
      "enum": ["SCENE_BUILDER"]
    },
    "runtime_stage": { "type": "string" },
    "sequence_contract": { "type": "object" },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "gate_id",
          "name",
          "metric",
          "operator",
          "value",
          "block_below",
          "weight",
          "repair_hint"
        ],
        "properties": {
          "gate_id": { "type": "string" },
          "name": { "type": "string" },
          "metric": { "type": "string" },
          "operator": { "type": "string", "enum": [">=", "<=", "=="] },
          "value": {},
          "block_below": { "type": ["number", "boolean"] },
          "weight": { "type": "number" },
          "repair_hint": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "score_bands": {
      "type": "object",
      "required": ["pass", "revise"],
      "properties": {
        "pass": { "type": "number" },
        "revise": { "type": "number" }
      }
    }
  },
  "additionalProperties": true
}