{
  "global": {
    "hard_fail_conditions": [
      "headline_unreadable_at_25_percent_scale",
      "brand_context_version_missing",
      "source_quote_or_stat_unverified",
      "more_than_three_competing_focal_points",
      "text_overflow",
      "forbidden_visual_style",
      "identity_mismatch",
      "unsafe_or_stereotyping_micro_semiotic_anchor"
