{
  "$schema": "../../schemas/subsystem-config.schema.json",
  "schema_id": "cmf.subsystem.config/v1",
  "subsystem_id": "CS-007",
  "name": "Theta Reset Validator",
  "version": "1.0",
  "priority_tier": "encoding",
  "research_basis": [
    "Neurocinematics",
    "EEG cut-response studies"
  ],
  "inputs": [
    "cut_map",
    "information_delta_per_cut",
    "semantic_novelty",
    "motion_change",
    "shot_purpose"
  ],
  "outputs": [
    "reset_value_score",
    "verdict",
    "redundant_cut_warnings"
  ],
  "thresholds": {
    "minimum_information_delta_per_cut": 1,
    "max_redundant_cut_run": 2,
    "require_semantic_novelty": true
  },
  "default_action_on_fail": "REVISE"
}