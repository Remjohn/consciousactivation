{
  "$schema": "../../schemas/subsystem-config.schema.json",
  "schema_id": "cmf.subsystem.config/v1",
  "subsystem_id": "CS-022",
  "name": "AV Sync Enforcer",
  "version": "1.0",
  "priority_tier": "quality",
  "research_basis": [
    "Audio-Visual Congruence"
  ],
  "inputs": [
    "audio_onset_ms",
    "visual_onset_ms",
    "event_type",
    "timing_offset_ms"
  ],
  "outputs": [
    "timing_error_ms",
    "verdict",
    "violations"
  ],
  "thresholds": {
    "preferred_sync_window_ms": {
      "min": -20,
      "max": 100
    },
    "speech_priority": true,
    "block_on_out_of_window_commit": true
  },
  "default_action_on_fail": "REVISE"
}