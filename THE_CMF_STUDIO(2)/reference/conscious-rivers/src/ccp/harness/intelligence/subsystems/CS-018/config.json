{
  "$schema": "../../schemas/subsystem-config.schema.json",
  "schema_id": "cmf.subsystem.config/v1",
  "subsystem_id": "CS-018",
  "name": "Presence/Arousal",
  "version": "1.0",
  "priority_tier": "encoding",
  "research_basis": [
    "Camera Motion",
    "Vection and presence studies"
  ],
  "inputs": [
    "effect_id",
    "predicted_presence_score",
    "predicted_arousal_score",
    "cls_cost",
    "scene_role"
  ],
  "outputs": [
    "ranked_motion_selection",
    "safe_use_guidance",
    "verdict"
  ],
  "thresholds": {
    "minimum_presence_arousal_ratio": 1.25,
    "max_standard_cls_cost": 2,
    "reserve_high_arousal_for": [
      "TURNING_POINT",
      "VISION"
    ]
  },
  "default_action_on_fail": "REVISE"
}