{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cmf.component.spec.schema.v1",
  "title": "CMF Component Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_id",
    "component_id",
    "scene_number",
    "name",
    "version",
    "function",
    "compatible_containers",
    "cls_footprint",
    "required_asset_types",
    "template_variants",
    "effect_dependencies",
    "selection_signals",
    "audio_profile",
    "fallback_behavior"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_id": {
      "const": "cmf.component.spec/v1"
    },
    "component_id": {
      "type": "string"
    },
    "scene_number": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "function": {
      "type": "string"
    },
    "compatible_containers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "cls_footprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typical", "max"],
      "properties": {
        "typical": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    },
    "required_asset_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "template_variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "effect_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selection_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audio_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score_role", "energy_band", "mode", "prosodic_hint"],
      "properties": {
        "score_role": {
          "type": "string"
        },
        "energy_band": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "prosodic_hint": {
          "type": "string"
        },
        "prosodic_contour_target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pitch_shape", "stress_placement", "rate_wpm", "emotional_register"],
          "properties": {
            "pitch_shape": {
              "enum": ["rising", "falling", "level", "circumflex", "rising_falling", "falling_rising"]
            },
            "stress_placement": {
              "enum": ["initial", "medial", "final", "distributed"]
            },
            "rate_wpm": {
              "type": "object",
              "additionalProperties": false,
              "required": ["min", "max"],
              "properties": {
                "min": { "type": "integer", "minimum": 60 },
                "max": { "type": "integer", "minimum": 60 }
              }
            },
            "emotional_register": {
              "type": "string"
            }
          }
        }
      }
    },
    "fallback_behavior": {
      "type": "string"
    }
  }
}