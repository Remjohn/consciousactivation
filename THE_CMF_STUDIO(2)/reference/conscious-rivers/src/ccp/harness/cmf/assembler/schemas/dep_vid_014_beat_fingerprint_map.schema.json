{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "DEP-VID-014",
  "title": "Beat Fingerprint Map",
  "description": "FR-VID-05 §5 — Complete fingerprint registry for all beats in a video. Each beat has an active fingerprint tracking T2I and I2V generation provenance, plus regeneration history.",
  "type": "object",
  "required": ["video_id", "project_id", "beat_cluster_id", "fingerprints", "summary"],
  "properties": {
    "video_id": {
      "type": "string",
      "pattern": "^CMF-VID-\\d{8}-\\d{3}$"
    },
    "project_id": {
      "type": "string"
    },
    "beat_cluster_id": {
      "type": "string"
    },
    "fingerprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["beat_index", "active_fingerprint_id", "fingerprint", "regeneration_history"],
        "properties": {
          "beat_index": {
            "type": "integer",
            "minimum": 0
          },
          "active_fingerprint_id": {
            "type": "string",
            "pattern": "^FP-VID-\\d{8}-\\d{3}-B\\d{2}$"
          },
          "fingerprint": {
            "type": "object",
            "required": ["fingerprint_id", "stage_1_t2i", "stage_2_i2v"],
            "properties": {
              "fingerprint_id": {
                "type": "string",
                "pattern": "^FP-VID-\\d{8}-\\d{3}-B\\d{2}$"
              },
              "stage_1_t2i": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["GENERATED", "PENDING"] },
                  "runninghub_workflow_id": { "type": "string" },
                  "prompt_used": { "type": "string" },
                  "negative_prompt": { "type": "string" },
                  "seed": { "type": ["integer", "null"] },
                  "model": { "type": "string" },
                  "pssl_params": { "type": "object" },
                  "output_image_url": { "type": "string" },
                  "quality_score": { "type": ["number", "null"] },
                  "generation_timestamp": { "type": "string" }
                }
              },
              "stage_2_i2v": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["GENERATED", "PENDING"] },
                  "runninghub_workflow_id": { "type": "string" },
                  "input_image_url": { "type": "string" },
                  "motion_parameters": { "type": "object" },
                  "output_video_url": { "type": "string" },
                  "seed_used": { "type": ["integer", "null"] },
                  "vram_tier_used": { "type": "string" },
                  "generation_timestamp": { "type": "string" }
                }
              }
            }
          },
          "regeneration_history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["superseded_fingerprint_id", "superseded_at", "reason", "mode", "new_fingerprint_id"],
              "properties": {
                "superseded_fingerprint_id": { "type": "string" },
                "superseded_at": { "type": "string" },
                "reason": { "type": "string" },
                "mode": { "type": "string", "enum": ["T2I_ONLY", "I2V_ONLY", "BOTH"] },
                "new_fingerprint_id": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_beats", "total_regenerations", "beats_with_regeneration"],
      "properties": {
        "total_beats": { "type": "integer", "minimum": 0 },
        "total_regenerations": { "type": "integer", "minimum": 0 },
        "beats_with_regeneration": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
