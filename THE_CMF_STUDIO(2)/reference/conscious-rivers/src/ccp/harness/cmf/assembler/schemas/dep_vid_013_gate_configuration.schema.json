{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DEP-VID-013 — Quality Gate Configuration",
  "description": "Configuration for the T2I Quality Gate: threshold, max retries, scoring weights, CLIP model (FR-VID-04).",
  "type": "object",
  "required": ["threshold", "max_retries", "weights", "clip_model"],
  "properties": {
    "threshold": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.6,
      "description": "Composite score threshold. Keyframes scoring below this fail the gate."
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "default": 2,
      "description": "Maximum regeneration attempts before MANUAL_REVIEW."
    },
    "weights": {
      "type": "object",
      "required": ["prompt_adherence", "composition_quality", "pssl_coherence", "artifact_detection"],
      "properties": {
        "prompt_adherence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.40 },
        "composition_quality": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.20 },
        "pssl_coherence": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.25 },
        "artifact_detection": { "type": "number", "minimum": 0.0, "maximum": 1.0, "default": 0.15 }
      },
      "description": "Scoring dimension weights. Must sum to 1.0."
    },
    "clip_model": {
      "type": "string",
      "default": "ViT-L/14",
      "description": "CLIP model variant to use for prompt adherence scoring."
    },
    "project_id": {
      "type": "string",
      "description": "CMF project identifier."
    },
    "visual_style": {
      "type": "string",
      "default": "photorealistic",
      "description": "Project visual style. Affects threshold and model recommendations."
    }
  }
}
